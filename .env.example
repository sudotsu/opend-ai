# Get your API key from https://venice.ai
VENICE_API_KEY=your_venice_api_key_here

# Optional: override the default model (olafangensan-glm-4.7-flash-heretic)
# VENICE_MODEL=your_preferred_model_id

# Optional: point at any OpenAI-compatible endpoint. Leave unset for Venice
# (the uncensored default). For a fully local, no-middleman uncensored setup,
# run an abliterated model in Ollama and use its base URL + model:
# VENICE_BASE_URL=http://localhost:11434/v1
# VENICE_MODEL=your-local-model
# (venice_parameters is only sent to Venice, so other providers won't choke.)

# Optional: system-prompt posture — "coding" (default) or "raw"
# VENICE_POSTURE=coding

# For everything else (context window size, retries, pricing, permission
# defaults, retention, and extra warning patterns) see .opendrc.example.json
