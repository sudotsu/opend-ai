{
  "name": "venice-agent",
  "version": "1.0.0",
  "description": "An uncensored, local-first CLI coding agent powered by Venice.ai — streams live reasoning, edits files, runs commands.",
  "keywords": [
    "cli",
    "ai-agent",
    "venice-ai",
    "coding-assistant",
    "uncensored-llm",
    "llm"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "venice-agent": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example",
    ".veniceagentrc.example.json"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "openai": "^4.82.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  }
}
