{
  "name": "opend-ai",
  "version": "0.2.0",
  "description": "An uncensored, local-first CLI coding agent — streams live reasoning, edits files, runs commands. Provider-agnostic, runs on any OpenAI-compatible uncensored LLM.",
  "keywords": [
    "cli",
    "ai-agent",
    "coding-assistant",
    "uncensored-llm",
    "llm",
    "venice-ai",
    "ollama",
    "openai-compatible"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "opend": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    ".env.example",
    ".veniceagentrc.example.json"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "openai": "^4.82.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.10"
  }
}
