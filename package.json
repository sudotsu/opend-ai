{
  "name": "opend-ai",
  "version": "0.2.0",
  "description": "An uncensored, local-first CLI coding agent — streams live reasoning, edits files, runs commands. Provider-agnostic, runs on any OpenAI-compatible uncensored LLM.",
  "keywords": [
    "cli",
    "ai-agent",
    "coding-assistant",
    "uncensored-llm",
    "llm",
    "venice-ai",
    "ollama",
    "openai-compatible"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22 <25"
  },
  "packageManager": "npm@11.9.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sudotsu/opend-ai.git"
  },
  "bugs": {
    "url": "https://github.com/sudotsu/opend-ai/issues"
  },
  "homepage": "https://github.com/sudotsu/opend-ai#readme",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "opend": "dist/index.js"
  },
  "files": [
    "dist",
    "assets/opend-ai-banner.svg",
    "docs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    ".env.example",
    ".opendrc.example.json"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "eval": "npm run build && node scripts/run-deterministic-evals.mjs",
    "eval:live": "npm run build && node scripts/run-live-evals.mjs",
    "test:cli": "npm run build && node scripts/cli-smoke.mjs",
    "check:release": "node scripts/check-release-facts.mjs"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "ignore": "^7.0.6",
    "openai": "^4.82.0",
    "re2js": "^2.8.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.10"
  }
}
